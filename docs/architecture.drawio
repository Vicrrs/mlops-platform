(~40 linhas, só parâmetros)" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="540" height="70" as="geometry" /></mxCell><mxCell id="n3" value="src/churn_model/  (features, treino, avaliação)" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="80" y="200" width="540" height="70" as="geometry" /></mxCell><mxCell id="n4" value="conf/ · resources/*.job.yml · databricks.yml" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="80" y="290" width="540" height="70" as="geometry" /></mxCell><mxCell id="n5" value="tests/{unit,spark,integration,smoke}" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="80" y="380" width="540" height="60" as="geometry" /></mxCell><mxCell id="n6" value="REPOSITÓRIO CENTRAL  —  mlops-platform" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6E9DD;strokeColor=#B8672E;verticalAlign=top;align=center;fontSize=14;fontStyle=1;fontColor=#182421;" vertex="1" parent="1"><mxGeometry x="900" y="40" width="620" height="420" as="geometry" /></mxCell><mxCell id="n7" value="pipelines/templates/ml-project-pipeline.yml
(22 stages)" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="940" y="100" width="540" height="70" as="geometry" /></mxCell><mxCell id="n8" value="scripts/*.py  — validação, comparação,
promoção, rollback (sem PySpark)" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="940" y="200" width="540" height="70" as="geometry" /></mxCell><mxCell id="n9" value="docs/  — 10 documentos de padrão e governança" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="940" y="290" width="540" height="70" as="geometry" /></mxCell><mxCell id="n10" value="project-template/  — ponto de partida (código real)" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="940" y="380" width="540" height="60" as="geometry" /></mxCell><mxCell id="n11" value="extends  (ref: refs/tags/v1.0.0)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#1E7F72;fontColor=#4C5A56;fontSize=11;endArrow=block;" edge="1" parent="1" source="n2" target="n7"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n12" value="chama" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B8672E;fontColor=#4C5A56;fontSize=11;endArrow=block;" edge="1" parent="1" source="n7" target="n8"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n13" value="copiado 1x, ao criar o projeto" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#7C8A86;fontColor=#4C5A56;fontSize=11;endArrow=block;dashed=1;" edge="1" parent="1" source="n10" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="n14" value="Princípio: o código do modelo NUNCA sai do repositório do time.
O repositório central só fornece lógica reutilizável (pipeline, validação, promoção, rollback) — nunca uma cópia do código de ninguém.
Cada projeto fixa a versão do template por TAG (nunca 'main'), então uma mudança no central não vira surpresa em produção." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C2BF;fontColor=#182421;fontSize=14;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="400" y="520" width="1120" height="130" as="geometry" /></mxCell></root></mxGraphModel></diagram><diagram name="2. Quem faz o quê" id="n97"><mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="n15" value="Engenheiro(a) / Cientista de ML" style="whiteSpace=wrap;html=1;fillColor=#EDF3F1;strokeColor=#1E7F72;fontColor=#182421;fontSize=15;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="60" width="340" height="90" as="geometry" /></mxCell><mxCell id="n16" value="Time dono do modelo.
Trabalha só no próprio repositório." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="60" y="160" width="340" height="70" as="geometry" /></mxCell><mxCell id="n17" value="Desenvolve localmente · ajusta features/algoritmo ·
define limites de qualidade em conf/base.yml · abre PR" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E7F72;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="60" y="240" width="340" height="140" as="geometry" /></mxCell><mxCell id="n18" value="Time de MLOps" style="whiteSpace=wrap;html=1;fillColor=#F6E9DD;strokeColor=#B8672E;fontColor=#182421;fontSize=15;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="440" y="60" width="340" height="90" as="geometry" /></mxCell><mxCell id="n19" value="Dono do repositório central
e da governança entre times." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="440" y="160" width="340" height="70" as="geometry" /></mxCell><mxCell id="n20" value="Mantém templates/scripts · revisa mudanças em
pipelines/, resources/, registry.py · publica novas tags" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B8672E;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="440" y="240" width="340" height="140" as="geometry" /></mxCell><mxCell id="n21" value="Aprovador de produção" style="whiteSpace=wrap;html=1;fillColor=#E4F2EA;strokeColor=#2E7D5B;fontColor=#182421;fontSize=15;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="60" width="340" height="90" as="geometry" /></mxCell><mxCell id="n22" value="Tech lead / product owner do modelo.
Não escreve YAML de pipeline." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D5B;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="820" y="160" width="340" height="70" as="geometry" /></mxCell><mxCell id="n23" value="Aceita (ou rejeita) o check de aprovação manual
no Environment databricks-prd antes de qualquer promoção" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D5B;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="820" y="240" width="340" height="140" as="geometry" /></mxCell><mxCell id="n24" value="A pipeline (automático)" style="whiteSpace=wrap;html=1;fillColor=#EEEEEC;strokeColor=#7C8A86;fontColor=#182421;fontSize=15;align=center;verticalAlign=middle;rounded=1;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1200" y="60" width="340" height="90" as="geometry" /></mxCell><mxCell id="n25" value="Tudo entre o merge do PR
e o pedido de aprovação." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7C8A86;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="1200" y="160" width="340" height="70" as="geometry" /></mxCell><mxCell id="n26" value="Valida, testa, treina, compara, aplica quality gates —
sem intervenção humana, e nunca promove sozinha" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7C8A86;fontColor=#182421;fontSize=12;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="1200" y="240" width="340" height="140" as="geometry" /></mxCell><mxCell id="n27" value="Fluxo de responsabilidade: Engenheiro(a) de ML abre o PR  →  a pipeline valida/testa/treina/compara sozinha  →  Aprovador aceita o gate manual  →  a pipeline promove e monitora  →  Time de MLOps mantém as regras que todo esse fluxo usa." style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B9C2BF;fontColor=#182421;fontSize=13;align=center;verticalAlign=middle;rounded=1;" vertex="1" parent="1"><mxGeometry x="60" y="430" width="1420" height="90" as="geometry" /></mxCell></root></mxGraphModel></diagram><diagram name="3. Pipeline - 22 stages" id="n98"><mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="n28" value="CI — sempre roda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDF3F1;strokeColor=#1E7F72;verticalAlign=top;align=center;fontSize=13;fontStyle=1;fontColor=#182421;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="260" height="50" as="geometry" /></mxCell><mxCell id="n29" value="Build — sempre roda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6E9DD;strokeColor=#B8672E;verticalAlign=top;align=center;fontSize=13;fontStyle=1;fontColor=#182421;" vertex="1" parent="1"><mxGeometry x="340" y="20" width="260" height="50" as="geometry" /></mxCell><mxCell id="n30" value="HML — não roda em PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBF0DC;strokeColor=#A5730A;verticalAlign=top;align=center;fontSize=13;fontStyle=1;fontColor=#182421;" vertex="1" parent="1"><mxGeometry x="640" y="20" width="260" height="50" as="geometry" /></mx